datasource db {
  provider     = "sqlite"
  url          = "file:./dev.db"
  relationMode = "prisma"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id                 String              @id
  name               String
  password           String              @default("")
  role               String              @default("affiliate")
  withdrawableBalance Float               @default(0.0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sales              Sale[]
  withdrawals        Withdrawal[]
  ledgerTransactions LedgerTransaction[]
}

model Sale {
  id             String         @id @default(uuid())
  userId         String
  brand          String
  earning        Float
  status         String         @default("pending") // pending, approved, rejected
  advancePaid    Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id])
  advancePayout  AdvancePayout?
}

model AdvancePayout {
  id        String   @id @default(uuid())
  saleId    String   @unique
  amount    Float
  createdAt DateTime @default(now())
  sale      Sale     @relation(fields: [saleId], references: [id])
}

model Withdrawal {
  id          String           @id @default(uuid())
  userId      String
  amount      Float
  status      String           @default("pending") // pending, success, failed, cancelled, rejected
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id])
}

model LedgerTransaction {
  id        String          @id @default(uuid())
  userId    String
  amount    Float           // Positive for credits, negative for debits
  type      String          // ADVANCE_PAYOUT, FINAL_PAYOUT_APPROVED, REJECTION_ADJUSTMENT, WITHDRAWAL, WITHDRAWAL_REFUND
  referenceId String        // References Sale ID or Withdrawal ID
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id])
}
